---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Hero Section -->
  <section class="mesh-gradient-container min-h-[70vh] flex flex-col items-center justify-center text-center px-6 relative py-20 border-b border-hairline">
    <!-- Mesh Blurs -->
    <div class="mesh-gradient-bg">
      <div class="mesh-blob-1"></div>
      <div class="mesh-blob-2"></div>
      <div class="mesh-blob-3"></div>
    </div>
    
    <div class="max-w-3xl mx-auto relative z-10 flex flex-col items-center gap-6">
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-accent-soft border border-accent/20 rounded-full">
        <span class="w-1.5 h-1.5 rounded-full bg-accent animate-ping"></span>
        <span class="text-caption-mono text-accent uppercase tracking-wider font-semibold">system online // active simulations</span>
      </div>
      
      <h1 class="text-display-xl md:text-[64px] md:leading-[64px] font-semibold text-ink tracking-[-2.4px] max-w-2xl">
        Explore the limits of artificial intelligence.
      </h1>
      
      <p class="text-body text-body-lg max-w-xl">
        Mind-blowing statistics, prompt injection games, scale comparisons, and timeline predictions. Step into the AI control room.
      </p>
      
      <div class="flex gap-4 mt-2">
        <a 
          href="#explore" 
          class="h-10 inline-flex items-center bg-accent text-on-primary text-button-md font-medium rounded-pill px-6 hover:bg-accent-deep active:scale-95 transition-all shadow-md shadow-accent/10"
        >
          Initialize Sandbox
        </a>
        <a 
          href="/experiences/spend-compute" 
          class="h-10 inline-flex items-center border border-hairline text-ink text-button-md font-medium rounded-pill px-6 hover:bg-canvas-soft-2 active:scale-95 transition-all"
        >
          Spend $10B Compute
        </a>
      </div>
    </div>
  </section>

  <!-- Experiences Grid Section -->
  <section id="explore" class="py-24 px-6 md:px-12 max-w-7xl mx-auto scroll-mt-16">
    <div class="flex flex-col gap-4 mb-16">
      <span class="text-caption-mono text-accent uppercase tracking-wider">real-time playgrounds</span>
      <h2 class="text-display-lg text-ink font-semibold tracking-[-1.28px]">
        Choose your experience.
      </h2>
      <p class="text-body text-body-md max-w-lg">
        Run client-side sandboxes. Test the engineering limits of parameters, budget allocation, alignment, and prediction.
      </p>
    </div>

    <!-- 2x2 Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
      
      <!-- Experience 1 -->
      <div class="group bg-canvas-card border border-hairline hover:border-accent rounded-lg p-8 flex flex-col justify-between gap-8 transition-all duration-300 hover:shadow-[0_0_24px_rgba(0,255,136,0.06)] relative overflow-hidden">
        <div class="flex flex-col gap-4">
          <span class="text-caption-mono text-mute tracking-wider group-hover:text-accent transition-colors">
            EXPERIENCE_01 // METRICS_RUN
          </span>
          <h3 class="text-display-md text-ink font-semibold tracking-[-0.96px]">
            Spend AI's Compute Budget
          </h3>
          <p class="text-body text-body-sm max-w-md">
            You are granted $10,000,000,000 to purchase H100/B200 GPUs, hire top machine learning researchers, lease nuclear facilities, and secure stackoverflow licences.
          </p>
        </div>
        <div>
          <a 
            href="/experiences/spend-compute" 
            class="inline-flex items-center justify-center bg-transparent border border-hairline group-hover:border-accent text-ink group-hover:text-on-primary group-hover:bg-accent text-button-md font-medium rounded-pill px-5 py-2.5 transition-all active:scale-95"
          >
            Allocate Budget
          </a>
        </div>
      </div>

      <!-- Experience 2 -->
      <div class="group bg-canvas-card border border-hairline hover:border-accent rounded-lg p-8 flex flex-col justify-between gap-8 transition-all duration-300 hover:shadow-[0_0_24px_rgba(0,255,136,0.06)] relative overflow-hidden">
        <div class="flex flex-col gap-4">
          <span class="text-caption-mono text-mute tracking-wider group-hover:text-accent transition-colors">
            EXPERIENCE_02 // SYSTEM_SECURITY
          </span>
          <h3 class="text-display-md text-ink font-semibold tracking-[-0.96px]">
            Jailbreak Sandbox
          </h3>
          <p class="text-body text-body-sm max-w-md">
            Attempt prompt injection against four levels of artificial security guardrails. Bypass filters, translate context, and trigger secret password output.
          </p>
        </div>
        <div>
          <a 
            href="/experiences/jailbreak" 
            class="inline-flex items-center justify-center bg-transparent border border-hairline group-hover:border-accent text-ink group-hover:text-on-primary group-hover:bg-accent text-button-md font-medium rounded-pill px-5 py-2.5 transition-all active:scale-95"
          >
            Attempt Injection
          </a>
        </div>
      </div>

      <!-- Experience 3 -->
      <div class="group bg-canvas-card border border-hairline hover:border-accent rounded-lg p-8 flex flex-col justify-between gap-8 transition-all duration-300 hover:shadow-[0_0_24px_rgba(0,255,136,0.06)] relative overflow-hidden">
        <div class="flex flex-col gap-4">
          <span class="text-caption-mono text-mute tracking-wider group-hover:text-accent transition-colors">
            EXPERIENCE_03 // DATA_VISUALIZATION
          </span>
          <h3 class="text-display-md text-ink font-semibold tracking-[-0.96px]">
            The Scale of AI
          </h3>
          <p class="text-body text-body-sm max-w-md">
            Explore the magnitude of AI networks. Scroll visually through parameter scales, comparing the Perceptron to BERT, LLaMA-3, and the human brain's synapses.
          </p>
        </div>
        <div>
          <a 
            href="/experiences/scale" 
            class="inline-flex items-center justify-center bg-transparent border border-hairline group-hover:border-accent text-ink group-hover:text-on-primary group-hover:bg-accent text-button-md font-medium rounded-pill px-5 py-2.5 transition-all active:scale-95"
          >
            Launch Visualizer
          </a>
        </div>
      </div>

      <!-- Experience 4 -->
      <div class="group bg-canvas-card border border-hairline hover:border-accent rounded-lg p-8 flex flex-col justify-between gap-8 transition-all duration-300 hover:shadow-[0_0_24px_rgba(0,255,136,0.06)] relative overflow-hidden">
        <div class="flex flex-col gap-4">
          <span class="text-caption-mono text-mute tracking-wider group-hover:text-accent transition-colors">
            EXPERIENCE_04 // DECISION_ENGINE
          </span>
          <h3 class="text-display-md text-ink font-semibold tracking-[-0.96px]">
            Predict the AI Timeline
          </h3>
          <p class="text-body text-body-sm max-w-md">
            When will we achieve AGI? Humanoid robot replacement? An AI Nobel Laureate? Plot your timelines and see how your predictions compare to experts.
          </p>
        </div>
        <div>
          <a 
            href="/experiences/timeline" 
            class="inline-flex items-center justify-center bg-transparent border border-hairline group-hover:border-accent text-ink group-hover:text-on-primary group-hover:bg-accent text-button-md font-medium rounded-pill px-5 py-2.5 transition-all active:scale-95"
          >
            Predict Timeline
          </a>
        </div>
      </div>

    </div>
  </section>
</Layout>
